# AdOps MCP — Environment Variables
# All integrations are optional. The server works without any API keys
# using local storage for campaign management and analytics.

# ─── Google Ads API (optional) ───────────────────────────────────────
# Required for live Google Ads data sync
# Get credentials: https://developers.google.com/google-ads/api/docs/first-call/overview
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ─── Meta Marketing API (optional) ──────────────────────────────────
# Required for live Meta/Facebook/Instagram Ads data sync
# Get credentials: https://developers.facebook.com/docs/marketing-apis/
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
